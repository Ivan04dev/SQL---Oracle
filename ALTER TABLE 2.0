DESC TAREAS_PROYECTOS;

-- Modificar columnas tipo CLOB a VARCHAR2

-- Columnas temporales

ALTER TABLE TAREAS_PROYECTOS ADD DESCRIPCION_TMP VARCHAR2(4000);
ALTER TABLE TAREAS_PROYECTOS ADD COMENTARIOS_TMP VARCHAR2(4000);

-- Copiar los datos

UPDATE TAREAS_PROYECTOS SET DESCRIPCION_TMP = SUBSTR(DESCRIPCION, 1, 4000);
UPDATE TAREAS_PROYECTOS SET COMENTARIOS_TMP = SUBSTR(COMENTARIOS, 1, 4000);

-- Eliminar las columnas anteriores

ALTER TABLE TAREAS_PROYECTOS DROP COLUMN DESCRIPCION;
ALTER TABLE TAREAS_PROYECTOS DROP COLUMN COMENTARIOS;

-- Renombrar

ALTER TABLE TAREAS_PROYECTOS RENAME COLUMN DESCRIPCION_TMP TO DESCRIPCION;
ALTER TABLE TAREAS_PROYECTOS RENAME COLUMN COMENTARIOS_TMP TO COMENTARIOS;
