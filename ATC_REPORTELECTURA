CREATE TABLE ATC_REPORTELECTURA(
    "ID" NUMBER,
    "IDLECTURA" NUMBER,
    "USUARIORED" VARCHAR2(20),
    "CIUDAD" VARCHAR2(30),
    "TITULO" VARCHAR2(300),
    "ESTATUS" VARCHAR2(15),
    "IP" VARCHAR2(30),
    "APERTURAPAG" TIMESTAMP (6),
    "FECHALEIDO" TIMESTAMP (6)
);

-- Crea la secuencia
CREATE SEQUENCE ATC_REPORTELECTURA_SEQ
START WITH 1
INCREMENT BY 1
NOCACHE
NOCYCLE;


CREATE OR REPLACE EDITIONABLE TRIGGER ATC_REPORTELECTURA_TRG
BEFORE INSERT ON ATC_REPORTELECTURA
FOR EACH ROW 
BEGIN
  IF INSERTING AND :NEW.ID IS NULL THEN
    SELECT ATC_REPORTELECTURA_SEQ.NEXTVAL INTO :NEW.ID FROM SYS.DUAL;
  END IF;
END;
/

-- Activa la secuencia
ALTER TRIGGER ATC_REPORTELECTURA_TRG ENABLE;

-- Verifica que esxista
SELECT trigger_name, status
FROM user_triggers
WHERE trigger_name = 'ATC_REPORTELECTURA_TRG';
